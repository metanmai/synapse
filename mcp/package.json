{
  "name": "synapsesync-mcp",
  "version": "0.6.2",
  "description": "MCP server for Synapse — shared AI context across tools and devices",
  "main": "dist/index.js",
  "bin": {
    "synapsesync-mcp": "dist/index.js"
  },
  "scripts": {
    "build": "tsc && node ./scripts/add-shebang.mjs",
    "test": "vitest run",
    "test:e2e": "TEST_E2E=1 vitest run test/e2e/",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "start": "node dist/index.js",
    "prepublishOnly": "npm install && npm run build"
  },
  "keywords": ["mcp", "synapse", "ai", "context", "claude", "chatgpt", "cursor"],
  "homepage": "https://synapsesync.app",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/metanmai/synapse.git",
    "directory": "mcp"
  },
  "bugs": {
    "url": "https://github.com/metanmai/synapse/issues"
  },
  "author": "metanmai",
  "license": "MIT",
  "type": "module",
  "files": ["dist/"],
  "dependencies": {
    "@clack/prompts": "^0.11.0",
    "@modelcontextprotocol/sdk": "1.27.1",
    "chokidar": "^5.0.0",
    "zod": "4.3.6"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "typescript": "^5.9.3",
    "vitest": "^4.1.2"
  }
}
