{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "mcp-sync",
  "main": "src/index.ts",
  "compatibility_date": "2025-04-01",
  "compatibility_flags": ["nodejs_compat"],
  "durable_objects": {
    "bindings": [
      {
        "class_name": "McpSyncAgent",
        "name": "MCP_OBJECT"
      }
    ]
  },
  "migrations": [
    {
      "new_sqlite_classes": ["McpSyncAgent"],
      "tag": "v1"
    }
  ],
  "triggers": {
    "crons": ["*/5 * * * *"]
  },
  "vars": {}
}
